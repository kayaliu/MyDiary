# 复制此文件为 .env 并填入你的配置

# AI 提供商: anthropic | openai | deepseek
AI_PROVIDER=anthropic

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (如用 GPT 系列)
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-chat

# 思源笔记 API Token (在思源「设置-关于」中获取)
SIYUAN_TOKEN=your-siyuan-token
# 思源笔记 API 地址 (默认本地)
SIYUAN_URL=http://127.0.0.1:6806
# 思源笔记日记所在笔记本ID (在思源笔记本列表右键复制ID)
SIYUAN_NOTEBOOK_ID=

# Express 服务端口（使用 SERVER_PORT 避免与 Vite 的 PORT 冲突）
SERVER_PORT=3001

# ── 飞书 (Feishu/Lark) Webhook ──────────────────────────────────────────────
# 在飞书开放平台创建自建应用后填入
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
# 事件订阅 → 请求网址验证时的 Verification Token
FEISHU_VERIFY_TOKEN=xxx
# 公网回调地址（使用 ngrok 或内网穿透）：POST /webhook/feishu
# FEISHU_WEBHOOK_URL=https://your-domain.com/webhook/feishu

# ── 企业微信 (WeCom) Webhook ─────────────────────────────────────────────────
# 在企业微信管理后台 → 应用 → 接收消息 配置
WECOM_TOKEN=xxx
WECOM_ENCODING_AES_KEY=xxx
WECOM_CORP_ID=xxx
# 公网回调地址：GET+POST /webhook/wecom
