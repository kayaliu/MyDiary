# 复制此文件为 .env 并填入你的配置

# AI 提供商: anthropic | openai | deepseek | openrouter | google | qianfan
AI_PROVIDER=anthropic

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1   # 可替换为任意兼容接口
# OPENAI_MODEL=gpt-4o

# ── DeepSeek ──────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_MODEL=deepseek-chat

# ── OpenRouter（免费模型 / 多模型聚合）────────────────────────────────────────
# 注册: https://openrouter.ai  →  API Keys
OPENROUTER_API_KEY=sk-or-xxx
# 免费模型示例（无需付费）:
#   meta-llama/llama-3.3-70b-instruct:free
#   qwen/qwen3-next-80b-a3b-instruct:free
#   google/gemini-2.0-flash-exp:free
# 付费/自动路由:
#   openrouter/auto
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Google Gemini ─────────────────────────────────────────────────────────────
# 注册: https://aistudio.google.com  →  Get API key
GOOGLE_API_KEY=AIza-xxx
# GOOGLE_MODEL=gemini-1.5-flash      # 免费额度较大
# GOOGLE_MODEL=gemini-1.5-pro
# GOOGLE_MODEL=gemini-2.0-flash-exp

# ── 百度千帆（Qianfan）────────────────────────────────────────────────────────
# 注册: https://qianfan.cloud.baidu.com  →  应用接入 → API Key
QIANFAN_API_KEY=your-qianfan-key
# QIANFAN_BASE_URL=https://qianfan.baidubce.com/v2
# QIANFAN_MODEL=deepseek-v3.2          # 或 ernie-4.5 等

# 思源笔记 API Token (在思源「设置-关于」中获取)
SIYUAN_TOKEN=your-siyuan-token
# 思源笔记 API 地址 (默认本地)
SIYUAN_URL=http://127.0.0.1:6806
# 思源笔记日记所在笔记本ID (在思源笔记本列表右键复制ID)
SIYUAN_NOTEBOOK_ID=

# Express 服务端口（使用 SERVER_PORT 避免与 Vite 的 PORT 冲突）
SERVER_PORT=3001

# ── 飞书 (Feishu/Lark) Webhook ──────────────────────────────────────────────
# 在飞书开放平台创建自建应用后填入
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
# 事件订阅 → 请求网址验证时的 Verification Token
FEISHU_VERIFY_TOKEN=xxx
# 公网回调地址（使用 ngrok 或内网穿透）：POST /webhook/feishu
# FEISHU_WEBHOOK_URL=https://your-domain.com/webhook/feishu

# ── 企业微信 (WeCom) Webhook ─────────────────────────────────────────────────
# 在企业微信管理后台 → 应用 → 接收消息 配置
WECOM_TOKEN=xxx
WECOM_ENCODING_AES_KEY=xxx
WECOM_CORP_ID=xxx
# 公网回调地址：GET+POST /webhook/wecom
